---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
	esArticulo, categoriaDeDoc, etiquetaCategoria, colorCategoria,
	INFO_CATEGORIAS, CATEGORIAS, minutosLectura,
} from '../../lib/categorias';

function hexToRgb(hex: string): string {
	const n = parseInt(hex.replace('#', ''), 16);
	return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
}
function fechaCorta(d?: Date): string {
	if (!d) return '';
	return new Intl.DateTimeFormat('es-ES', { month: 'short', year: 'numeric' }).format(d).replace('.', '');
}

const all = await getCollection('docs');
const articulos = all
	.filter(esArticulo)
	.sort((a, b) => {
		const ta = (a.data.pubDate as Date | undefined)?.getTime() ?? 0;
		const tb = (b.data.pubDate as Date | undefined)?.getTime() ?? 0;
		return tb - ta;
	})
	.map((doc) => ({
		id: doc.id,
		catKey: categoriaDeDoc(doc)!,
		cat: etiquetaCategoria(doc),
		color: colorCategoria(doc),
		title: doc.data.title,
		excerpt: doc.data.description ?? '',
		date: fechaCorta(doc.data.pubDate as Date | undefined),
		read: `${minutosLectura(doc)} min`,
	}));
---

<StarlightPage frontmatter={{ title: 'Todos los artículos', description: 'Archivo completo de Anatomía del Producto.', landing: true }}>
	<div class="adp-page archivo">
		<section class="archivo-head">
			<div class="hero-kicker">Archivo completo</div>
			<h1 class="archivo-title">Todos los artículos</h1>

			<label class="big-search">
				<span class="ico" aria-hidden="true">⌕</span>
				<input type="text" id="archivo-q" placeholder="Buscar por título, tema o palabra clave…" autocomplete="off" />
				<span class="count" id="archivo-count">{articulos.length} resultados</span>
			</label>

			<div class="filters" id="archivo-filters">
				<button type="button" class="filter is-active" data-cat="">Todos</button>
				{CATEGORIAS.map((cat) => (
					<button
						type="button"
						class="filter"
						data-cat={cat}
						style={`--cat:${INFO_CATEGORIAS[cat].color};--cat-rgb:${hexToRgb(INFO_CATEGORIAS[cat].color)}`}
					>{INFO_CATEGORIAS[cat].label}</button>
				))}
			</div>
		</section>

		<section class="archivo-list" id="archivo-list">
			{articulos.map((a) => (
				<a
					href={`/${a.id}/`}
					class="article-row"
					data-cat={a.catKey}
					data-text={`${a.title} ${a.excerpt} ${a.cat}`.toLowerCase()}
					style={`--cat:${a.color}`}
				>
					<span class="article-meta">
						<span class="chip" style={`--cat:${a.color};--cat-rgb:${hexToRgb(a.color)}`}>{a.cat}</span>
						<span class="date">{a.date} · {a.read}</span>
					</span>
					<span>
						<span class="title">{a.title}</span>
						<span class="excerpt">{a.excerpt}</span>
					</span>
					<span class="arrow">→</span>
				</a>
			))}
			<div class="no-results" id="archivo-empty" hidden>No hay artículos que coincidan con tu búsqueda.</div>
		</section>
	</div>

	<script is:inline>
		(function () {
			const q = document.getElementById('archivo-q');
			const filters = document.getElementById('archivo-filters');
			const rows = Array.from(document.querySelectorAll('#archivo-list .article-row'));
			const count = document.getElementById('archivo-count');
			const empty = document.getElementById('archivo-empty');
			let cat = '';

			function apply() {
				const term = (q.value || '').toLowerCase().trim();
				let visible = 0;
				rows.forEach((row) => {
					const matchCat = !cat || row.dataset.cat === cat;
					const matchText = !term || row.dataset.text.includes(term);
					const show = matchCat && matchText;
					row.style.display = show ? '' : 'none';
					if (show) visible++;
				});
				count.textContent = visible + (visible === 1 ? ' resultado' : ' resultados');
				empty.hidden = visible !== 0;
			}

			q.addEventListener('input', apply);
			filters.addEventListener('click', (e) => {
				const btn = e.target.closest('.filter');
				if (!btn) return;
				cat = btn.dataset.cat;
				filters.querySelectorAll('.filter').forEach((b) => b.classList.toggle('is-active', b === btn));
				apply();
			});
		})();
	</script>
</StarlightPage>
