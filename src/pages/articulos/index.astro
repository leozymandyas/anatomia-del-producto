---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const SECCIONES = ['cabeza', 'caja-toracica', 'extremidades'];

const allDocs = await getCollection('docs');

interface ArticuloItem {
	id: string;
	title: string;
	description: string | undefined;
	seccion: string;
	tags: string[];
}

function slugifyTag(tag: string) {
	return tag.toLowerCase().replace(/\s+/g, '-');
}

function seccionLabel(id: string) {
	if (id.startsWith('cabeza/')) return 'Cabeza';
	if (id.startsWith('caja-toracica/')) return 'Caja torácica';
	if (id.startsWith('extremidades/')) return 'Extremidades';
	return '';
}

const articulos: ArticuloItem[] = allDocs
	.filter((doc) => SECCIONES.some((s) => doc.id.startsWith(s + '/')))
	.sort((a, b) => a.data.title.localeCompare(b.data.title, 'es'))
	.map((doc) => ({
		id: doc.id,
		title: doc.data.title,
		description: doc.data.description,
		seccion: seccionLabel(doc.id),
		tags: (doc.data.tags ?? []) as string[],
	}));
---

<StarlightPage frontmatter={{ title: 'Todos los artículos', description: 'Índice completo de artículos de Anatomía del Producto.' }}>
	<p class="article-count">{articulos.length} artículos publicados.</p>

	<ul class="article-list">
		{articulos.map((art) => (
			<li>
				<a href={`/${art.id}/`} class="article-link">
					<div class="article-meta">
						<span class="article-seccion">{art.seccion}</span>
					</div>
					<span class="article-title">{art.title}</span>
					{art.description && (
						<span class="article-description">{art.description}</span>
					)}
				</a>
				{art.tags.length > 0 && (
					<div class="article-tags">
						{art.tags.map((tag) => (
							<a href={`/tags/${slugifyTag(tag)}/`} class="tag-chip">{tag}</a>
						))}
					</div>
				)}
			</li>
		))}
	</ul>
</StarlightPage>

<style>
	.article-count {
		color: var(--c-text-muted);
		font-size: 0.95rem;
	}

	.article-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-block: 1.5rem;
	}

	.article-list li {
		background-color: var(--c-surface);
		border: 1px solid var(--c-border);
		border-radius: var(--radius-md);
		padding: 1.15rem 1.35rem;
		box-shadow: var(--shadow-sm);
		transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
	}

	.article-list li:hover {
		border-color: var(--c-navy);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.article-link {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		text-decoration: none;
		color: var(--c-text);
	}

	.article-meta {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.article-seccion {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-navy);
	}

	.article-title {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--c-text-strong);
		line-height: 1.25;
	}

	.article-link:hover .article-title {
		color: var(--c-navy);
	}

	.article-description {
		font-size: 0.9rem;
		color: var(--c-text-muted);
		line-height: 1.5;
		margin-top: 0.1rem;
	}

	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.85rem;
	}
</style>
