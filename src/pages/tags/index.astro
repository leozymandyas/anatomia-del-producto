---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { esArticulo } from '../../lib/categorias';

const allDocs = await getCollection('docs');
const articulos = allDocs.filter((doc) => esArticulo(doc));

const tagCounts: Record<string, number> = {};
for (const doc of articulos) {
	const tags = ((doc.data as Record<string, unknown>).tags ?? []) as string[];
	for (const tag of tags) {
		tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
	}
}

function slugifyTag(tag: string) {
	return tag.toLowerCase().replace(/\s+/g, '-');
}

const tags = Object.entries(tagCounts).sort(([a], [b]) => a.localeCompare(b, 'es'));
---

<StarlightPage frontmatter={{ title: 'Temas', description: 'Artículos organizados por tema.', landing: true }}>
	<div class="adp-page archivo">
		<section class="archivo-head">
			<div class="hero-kicker">Por tema</div>
			<h1 class="archivo-title">Temas</h1>
			<p class="archivo-intro">Explora los artículos agrupados por tema.</p>
			<div class="tema-list">
				{tags.map(([tag, count]) => (
					<a href={`/tags/${slugifyTag(tag)}/`} class="tema-chip">
						{tag}
						<span class="tema-count">{count}</span>
					</a>
				))}
			</div>
		</section>
	</div>
</StarlightPage>
