---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { esArticulo } from '../../lib/regiones';

function slugifyTag(tag: string) {
	return tag.toLowerCase().replace(/\s+/g, '-');
}

interface ArticuloItem {
	id: string;
	title: string;
	description: string | undefined;
	tags: string[];
}

export async function getStaticPaths() {
	function slugifyTag(tag: string) {
		return tag.toLowerCase().replace(/\s+/g, '-');
	}

	const allDocs = await getCollection('docs');
	const articulos = allDocs.filter((doc) => esArticulo(doc));

	const tagMap: Record<string, ArticuloItem[]> = {};
	for (const doc of articulos) {
		const tags = (doc.data.tags ?? []) as string[];
		for (const tag of tags) {
			const slug = slugifyTag(tag);
			if (!tagMap[slug]) tagMap[slug] = [];
			tagMap[slug].push({
				id: doc.id,
				title: doc.data.title,
				description: doc.data.description,
				tags,
			});
		}
	}

	return Object.entries(tagMap).map(([slug, items]) => ({
		params: { tag: slug },
		props: {
			tagLabel: items[0].tags.find((t) => slugifyTag(t) === slug) ?? slug,
			articulos: items.sort((a, b) => a.title.localeCompare(b.title, 'es')),
		},
	}));
}

const { tagLabel, articulos } = Astro.props as {
	tagLabel: string;
	articulos: ArticuloItem[];
};
---

<StarlightPage
	frontmatter={{
		title: `Tag: ${tagLabel}`,
		description: `Artículos sobre ${tagLabel} en Anatomía del Producto.`,
	}}
>
	<p>
		{articulos.length} artículo{articulos.length !== 1 ? 's' : ''} con el tag <strong>{tagLabel}</strong>.
	</p>

	<ul class="article-list">
		{articulos.map((art) => (
			<li>
				<a href={`/${art.id}/`} class="article-link">
					<span class="article-title">{art.title}</span>
					{art.description && (
						<span class="article-description">{art.description}</span>
					)}
				</a>
				{art.tags.length > 0 && (
					<div class="article-tags">
						{art.tags.map((tag) => (
							<a href={`/tags/${slugifyTag(tag)}/`} class="tag-chip">{tag}</a>
						))}
					</div>
				)}
			</li>
		))}
	</ul>

	<a href="/tags/" class="back-link">← Ver todos los tags</a>
</StarlightPage>

<style>
	.article-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-block: 1.5rem;
	}

	.article-list li {
		background-color: var(--c-surface);
		border: 1px solid var(--c-border);
		border-radius: var(--radius-md);
		padding: 1.15rem 1.35rem;
		box-shadow: var(--shadow-sm);
		transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
	}

	.article-list li:hover {
		border-color: var(--c-navy);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.article-link {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		text-decoration: none;
		color: var(--c-text);
	}

	.article-title {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--c-text-strong);
		line-height: 1.25;
	}

	.article-link:hover .article-title {
		color: var(--c-navy);
	}

	.article-description {
		font-size: 0.9rem;
		color: var(--c-text-muted);
		line-height: 1.5;
	}

	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.85rem;
	}

	.back-link {
		display: inline-block;
		margin-top: 0.5rem;
		font-size: 0.9rem;
		color: var(--c-navy);
		text-decoration: none;
		font-weight: 600;
	}

	.back-link:hover {
		color: var(--c-navy-dark);
		text-decoration: underline;
	}
</style>
