---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
	esArticulo, categoriaDeDoc, etiquetaCategoria, colorCategoria, minutosLectura,
} from '../../lib/categorias';

function hexToRgb(hex: string): string {
	const n = parseInt(hex.replace('#', ''), 16);
	return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
}

interface ArticuloItem {
	id: string; title: string; excerpt: string;
	cat: string; catKey: string; color: string; date: string; read: string;
}

export async function getStaticPaths() {
	// getStaticPaths corre aislado: define aquí los helpers locales (solo los
	// imports están disponibles, no las funciones del frontmatter).
	const slugifyTag = (tag: string) => tag.toLowerCase().replace(/\s+/g, '-');
	const fechaCorta = (d?: Date) =>
		d ? new Intl.DateTimeFormat('es-ES', { month: 'short', year: 'numeric' }).format(d).replace('.', '') : '';

	const allDocs = await getCollection('docs');
	const articulos = allDocs.filter((doc) => esArticulo(doc));

	const tagMap: Record<string, { label: string; items: ArticuloItem[] }> = {};
	for (const doc of articulos) {
		const tags = (doc.data.tags ?? []) as string[];
		const item: ArticuloItem = {
			id: doc.id,
			title: doc.data.title,
			excerpt: doc.data.description ?? '',
			cat: etiquetaCategoria(doc),
			catKey: categoriaDeDoc(doc)!,
			color: colorCategoria(doc),
			date: fechaCorta(doc.data.pubDate as Date | undefined),
			read: `${minutosLectura(doc)} min`,
		};
		for (const tag of tags) {
			const slug = slugifyTag(tag);
			if (!tagMap[slug]) tagMap[slug] = { label: tag, items: [] };
			tagMap[slug].items.push(item);
		}
	}

	return Object.entries(tagMap).map(([slug, { label, items }]) => ({
		params: { tag: slug },
		props: { tagLabel: label, articulos: items.sort((a, b) => a.title.localeCompare(b.title, 'es')) },
	}));
}

const { tagLabel, articulos } = Astro.props as { tagLabel: string; articulos: ArticuloItem[] };
---

<StarlightPage
	frontmatter={{ title: `Tema: ${tagLabel}`, description: `Artículos sobre ${tagLabel}.`, landing: true }}
>
	<div class="adp-page archivo">
		<section class="archivo-head">
			<div class="hero-kicker">Tema</div>
			<h1 class="archivo-title">{tagLabel}</h1>
			<p class="archivo-intro">
				{articulos.length} artículo{articulos.length !== 1 ? 's' : ''} ·{' '}
				<a href="/tags/" class="archivo-back">ver todos los temas</a>
			</p>
		</section>

		<section class="archivo-list">
			{articulos.map((a) => (
				<a href={`/${a.id}/`} class="article-row" style={`--cat:${a.color}`}>
					<span class="article-meta">
						<span class="chip" style={`--cat:${a.color};--cat-rgb:${hexToRgb(a.color)}`}>{a.cat}</span>
						<span class="date">{a.date} · {a.read}</span>
					</span>
					<span>
						<span class="title">{a.title}</span>
						<span class="excerpt">{a.excerpt}</span>
					</span>
					<span class="arrow">→</span>
				</a>
			))}
		</section>
	</div>
</StarlightPage>
