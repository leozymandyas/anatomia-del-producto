---
import { getCollection } from 'astro:content';
import { etiquetaCategoria, colorCategoria } from '../lib/categorias';

interface Props {
	ids: string[];
}
const { ids } = Astro.props;

function hexToRgb(hex: string): string {
	const n = parseInt(hex.replace('#', ''), 16);
	return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
}

const allDocs = await getCollection('docs');
const articles = (ids ?? [])
	.map((id) => allDocs.find((doc) => doc.id === id))
	.filter(Boolean) as typeof allDocs;
---

{articles.length > 0 && (
	<section class="related">
		<div class="section-head"><span>Artículos relacionados</span></div>
		<div class="related-grid">
			{articles.map((a) => {
				const color = colorCategoria(a);
				return (
					<a href={`/${a.id}/`} class="related-card" style={`--cat:${color};--cat-rgb:${hexToRgb(color)}`}>
						<span class="chip">{etiquetaCategoria(a)}</span>
						<span class="related-title">{a.data.title}</span>
						{a.data.description && <span class="related-desc">{a.data.description}</span>}
					</a>
				);
			})}
		</div>
	</section>
)}
