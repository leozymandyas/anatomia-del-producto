---
import { getCollection } from 'astro:content';

interface Props {
	ids: string[];
}

const { ids } = Astro.props;

if (!ids || ids.length === 0) return;

const allDocs = await getCollection('docs');
const articles = ids
	.map((id) => allDocs.find((doc) => doc.id === id))
	.filter(Boolean) as typeof allDocs;
---

{articles.length > 0 && (
	<aside class="related-articles">
		<p class="related-label">Artículos relacionados</p>
		<div class="related-grid">
			{articles.map((art) => (
				<a href={`/${art.id}/`} class="related-card">
					<span class="related-card-title">{art.data.title}</span>
					{art.data.description && (
						<span class="related-card-desc">{art.data.description}</span>
					)}
				</a>
			))}
		</div>
	</aside>
)}

<style>
	.related-articles {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--sl-color-hairline);
	}

	.related-label {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--c-navy);
		margin-bottom: 0.9rem;
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
		gap: 0.8rem;
	}

	.related-card {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding: 1rem 1.1rem;
		background-color: var(--c-surface);
		border: 1px solid var(--c-border);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
	}

	.related-card:hover {
		border-color: var(--c-navy);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.related-card-title {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1rem;
		font-weight: 600;
		color: var(--c-text-strong);
		line-height: 1.3;
	}

	.related-card-desc {
		font-size: 0.8rem;
		color: var(--c-text-muted);
		line-height: 1.45;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
