---
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';

const isLanding = !!(Astro.locals.starlightRoute.entry.data as Record<string, unknown>).landing;
---

{/* TOC en escritorio va integrado en el sidebar izquierdo (ver Sidebar.astro).
    Aquí solo mantenemos el TOC colapsable de móvil, salvo en portadas. */}
{
	!isLanding && Astro.locals.starlightRoute.toc && (
		<div class="lg:sl-hidden">
			<MobileTableOfContents />
		</div>
	)
}
