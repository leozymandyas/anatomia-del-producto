---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import Search from 'virtual:starlight/components/Search';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarWithToc from '../SidebarWithToc.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

{/* Restaurar estado colapsado antes del primer paint (sin flash) */}
<script is:inline>
	(function () {
		if (localStorage.getItem('sidebar-collapsed') === 'true') {
			document.documentElement.setAttribute('data-sidebar-collapsed', '');
		}
	})();
</script>

<div class="sidebar-brand">
	<a href="/" class="brand-link">
		<img src="/favicon.svg" alt="" aria-hidden="true" class="brand-logo" />
		<span class="brand-name">Anatomía del Producto</span>
	</a>
	<button class="collapse-btn" id="sidebar-toggle" aria-label="Colapsar menú">
		<svg aria-hidden="true" width="14" height="14" viewBox="0 0 520 520" xmlns="http://www.w3.org/2000/svg">
			<rect x="104" y="155" width="312" height="36" rx="4" fill="rgb(61,90,224)"/>
			<rect x="104" y="242" width="312" height="36" rx="4" fill="rgb(61,90,224)"/>
			<rect x="104" y="329" width="312" height="36" rx="4" fill="rgb(61,90,224)"/>
		</svg>
	</button>
</div>

<div class="sidebar-search-wrapper">
	<Search />
</div>

<SidebarPersister>
	<SidebarWithToc sublist={sidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<footer class="sidebar-footer">
	<span class="sidebar-footer-text">
		&copy; {new Date().getFullYear()} Leonardo Ruano Hernández
	</span>
</footer>

<script>
	const btn = document.getElementById('sidebar-toggle');
	btn?.addEventListener('click', () => {
		const collapsed = document.documentElement.hasAttribute('data-sidebar-collapsed');
		document.documentElement.toggleAttribute('data-sidebar-collapsed', !collapsed);
		localStorage.setItem('sidebar-collapsed', String(!collapsed));
	});
</script>

<style>
	/* Oculto en móvil — el header nativo ya muestra el título del sitio */
	.sidebar-brand {
		display: none;
	}

	@media (min-width: 50rem) {
		.sidebar-brand {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.5rem;
			padding-bottom: 0.75rem;
			border-bottom: 1px solid var(--sl-color-hairline);
			margin-bottom: 0.25rem;
			/* Sticky: stays visible when scrolling the sidebar */
			position: sticky;
			top: 0;
			z-index: 1;
			background-color: var(--c-bg-sidebar);
			padding-top: 0.5rem;
		}

		.brand-link {
			display: flex;
			align-items: center;
			gap: 0.55rem;
			text-decoration: none;
			color: var(--c-navy);
			font-family: 'Fraunces', serif;
			font-size: 1rem;
			font-weight: 700;
			line-height: 1.2;
			min-width: 0;
		}

		.brand-logo {
			width: 30px;
			height: 30px;
			flex-shrink: 0;
		}

		.brand-name {
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
			transition: opacity 0.15s, width 0.15s;
		}

		.collapse-btn {
			flex-shrink: 0;
			display: flex;
			align-items: center;
			justify-content: center;
			width: 1.75rem;
			height: 1.75rem;
			border: 1px solid var(--sl-color-hairline);
			border-radius: 0.375rem;
			background: transparent;
			color: var(--c-gray-3);
			cursor: pointer;
			transition: background-color 0.15s, color 0.15s, transform 0.2s;
		}

.collapse-btn:hover {
			background-color: rgba(61, 90, 224, 0.12); /* --c-navy al 12% */
			color: var(--c-navy);
		}
	}

	.sidebar-footer {
		margin-top: auto;
		padding-top: 1rem;
		padding-bottom: 0.75rem;
		border-top: 1px solid var(--sl-color-hairline);
	}

	.sidebar-footer-text {
		display: block;
		font-size: 0.7rem;
		color: var(--sl-color-gray-4);
		text-align: center;
		line-height: 1.5;
	}

	[data-sidebar-collapsed] .sidebar-footer-text {
		display: none;
	}
</style>
