---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import Search from 'virtual:starlight/components/Search';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarWithToc from '../SidebarWithToc.astro';

const { sidebar, toc } = Astro.locals.starlightRoute;
---

<div class="sidebar-brand">
	<a href="/" class="brand-link">
		<img src="/favicon.svg" alt="" aria-hidden="true" class="brand-logo" />
		<span class="brand-name">Anatomía del Producto</span>
	</a>
	<a href="/contacto/" class="brand-contact">Contacto</a>
</div>

<div class="sidebar-search-wrapper">
	<Search />
</div>

<SidebarPersister>
	<SidebarWithToc sublist={sidebar} toc={toc} />
</SidebarPersister>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<style>
	.sidebar-brand {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--sl-color-hairline);
		margin-bottom: 0.25rem;
	}

	.brand-link {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		color: #542C14;
		font-family: 'Alegreya', serif;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.2;
		min-width: 0;
	}

	.brand-logo {
		width: 30px;
		height: 30px;
		flex-shrink: 0;
	}

	.brand-name {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.brand-contact {
		flex-shrink: 0;
		font-size: 0.72rem;
		font-weight: 600;
		color: #542C14;
		text-decoration: none;
		padding: 0.2rem 0.55rem;
		border: 1.5px solid #A89080;
		border-radius: 0.375rem;
		white-space: nowrap;
		transition: background-color 0.15s, border-color 0.15s;
	}

	.brand-contact:hover {
		background-color: rgba(106, 81, 66, 0.1);
		border-color: #7A6A60;
	}
</style>
