---
const { entry } = Astro.locals.starlightRoute;
const data = entry.data as Record<string, unknown>;
const isLanding = !!data.landing;
const icon = data.icon as string | undefined;
const isImage = !!icon && (icon.startsWith('/') || icon.startsWith('http://') || icon.startsWith('https://'));
const isEmoji = !!icon && !isImage;
---

{/* Las portadas (landing: true) ocultan el título automático: el hero lo reemplaza. */}
{!isLanding && (
	<div class:list={['page-title-wrap', { 'has-icon': !!icon }]}>
		{isImage && <img src={icon} alt="" aria-hidden="true" class="page-title-icon-img" />}
		{isEmoji && <span class="page-title-icon" aria-hidden="true">{icon}</span>}
		<h1 id="_top">{entry.data.title}</h1>
	</div>
)}

<style>
	.page-title-wrap {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.page-title-icon {
		font-size: 2rem;
		line-height: 1;
		flex-shrink: 0;
	}

	.page-title-icon-img {
		width: 2.5rem;
		height: 2.5rem;
		object-fit: contain;
		flex-shrink: 0;
	}
</style>
