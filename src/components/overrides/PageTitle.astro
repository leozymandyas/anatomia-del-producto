---
import BrandMark from '../BrandMark.astro';
import { categoriaDeDoc, etiquetaCategoria, minutosLectura } from '../../lib/categorias';

const { entry } = Astro.locals.starlightRoute;
const data = entry.data as Record<string, unknown>;
const isLanding = !!data.landing;

const cat = categoriaDeDoc(entry);
const catLabel = etiquetaCategoria(entry);
const isArticle = !!cat;

const pubDate = data.pubDate as Date | undefined;
const fecha = pubDate
	? new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }).format(pubDate)
	: '';
const lectura = isArticle ? `${minutosLectura(entry)} min de lectura` : '';
---

{!isLanding && (isArticle ? (
	<div class="article-head">
		<div class="article-head-glow" aria-hidden="true"></div>
		<div class="article-head-card">
			<div class="crumb"><a href="/articulos/">Artículos</a> &nbsp;/&nbsp; <span>{catLabel}</span></div>
			<span class="chip" style="--cat:var(--accent);--cat-rgb:var(--accent-rgb)">{catLabel}</span>
			<h1 id="_top">{entry.data.title}</h1>
			<div class="article-byline">
				<span class="byline-mark" aria-hidden="true"><BrandMark /></span>
				<span>Leonardo Ruano Hernández{fecha && ` · ${fecha}`}{lectura && ` · ${lectura}`}</span>
			</div>
		</div>
	</div>
) : (
	<div class="page-title-simple">
		<h1 id="_top">{entry.data.title}</h1>
	</div>
))}
