---
import '@astrojs/starlight/style/markdown.css';

const entry = Astro.locals.starlightRoute.entry;
const data = entry.data as Record<string, unknown>;
const tags = (data.tags ?? []) as string[];
const pageTheme = (data.pageTheme ?? '') as string;

function slugifyTag(tag: string) {
	return tag.toLowerCase().replace(/\s+/g, '-');
}
---

<div class="sl-markdown-content" data-page-theme={pageTheme || undefined}>
	{
		tags.length > 0 && (
			<div class="article-tags-header">
				{tags.map((tag) => (
					<a href={`/tags/${slugifyTag(tag)}/`} class="tag-chip">
						{tag}
					</a>
				))}
			</div>
		)
	}
	<slot />
</div>
