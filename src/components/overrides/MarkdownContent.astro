---
import '@astrojs/starlight/style/markdown.css';
import RelatedArticles from '../RelatedArticles.astro';
import ArticlePagination from '../ArticlePagination.astro';
import { esArticulo } from '../../lib/categorias';

const { entry } = Astro.locals.starlightRoute;
const data = entry.data as Record<string, unknown>;
const isLanding = !!data.landing;
const isArticle = esArticulo(entry);
const relatedArticles = (data.relatedArticles ?? []) as string[];
---

<div class="sl-markdown-content" data-landing={isLanding ? '' : undefined}>
	<slot />
	{isArticle && <RelatedArticles ids={relatedArticles} />}
	{isArticle && <ArticlePagination />}
</div>
