---
import '@astrojs/starlight/style/markdown.css';
import RelatedArticles from '../RelatedArticles.astro';
import Pagination from 'virtual:starlight/components/Pagination';

const entry = Astro.locals.starlightRoute.entry;
const data = entry.data as Record<string, unknown>;
const tags = (data.tags ?? []) as string[];
const pageTheme = (data.pageTheme ?? '') as string;
const relatedArticles = (data.relatedArticles ?? []) as string[];

// Las portadas (landing) no muestran paginación anterior/siguiente.
const isLanding = !!data.landing;

function slugifyTag(tag: string) {
	return tag.toLowerCase().replace(/\s+/g, '-');
}
---

<div class="sl-markdown-content" data-page-theme={pageTheme || undefined} data-landing={isLanding ? '' : undefined}>
	{tags.length > 0 && (
		<div class="article-tags-header">
			{tags.map((tag) => (
				<a href={`/tags/${slugifyTag(tag)}/`} class="tag-chip">{tag}</a>
			))}
		</div>
	)}
	<slot />
	<RelatedArticles ids={relatedArticles} />
	{!isLanding && <Pagination />}
</div>
